{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "register/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/STARRY.php"
    }
  ]
}
