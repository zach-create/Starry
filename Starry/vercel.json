{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*\\.php)$",
      "dest": "/api/index.php?route=$1"
    }
  ]
}
